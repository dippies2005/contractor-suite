{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Contractor Suite Desktop",
  "version": "0.1.0",
  "identifier": "com.contractorsuite.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "https://contractor-suite-admin-live.vercel.app",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Contractor Suite Desktop",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}